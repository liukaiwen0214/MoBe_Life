<?xml version="1.0" encoding="UTF-8"?>
<!--
  核心职责：定义后端日志输出策略，包括控制台输出、文件滚动和不同包的日志级别。
  所属业务模块：后端基础设施 / 日志配置。
  重要依赖关系或外部约束：日志路径、滚动策略和日志级别会直接影响排障效率、磁盘占用和运行性能。
-->
<configuration>

  <!-- 使用绝对路径，避免因为启动工作目录不同而写到意料之外的位置。 -->
  <!-- <property name="LOG_PATH" value="/www/wwwroot/mobe-life/backend/logs" /> -->
  <property name="LOG_PATH" value="/Users/liukaiwen/Desktop/MoBe_Life/mobe-life-backend/logs" />

  <!-- 控制台输出：适合本地开发和容器日志采集场景。 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- 文件输出：按日期和大小滚动，作为正式业务日志保留。 -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/mobe.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>15</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- 固定文件输出：专门给宝塔日志黑框读取。 -->
  <appender name="BT_FILE" class="ch.qos.logback.core.FileAppender">
    <file>${LOG_PATH}/app_jar.log</file>
    <append>true</append>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- 业务包日志适当放宽到 DEBUG，便于定位业务逻辑问题。 -->
  <logger name="com.mobe.mobe_life_backend" level="DEBUG" />
  <logger name="javax.management" level="WARN" />
  <logger name="javax.management.remote.rmi" level="WARN" />
  <logger name="javax.management.mbeanserver" level="WARN" />
  <logger name="sun.rmi" level="WARN" />
  <logger name="org.springframework" level="INFO" />
  <logger name="org.mybatis" level="INFO" />

  <!-- 根日志器同时输出到控制台、滚动文件和固定文件。 -->
  <root level="INFO">
    <appender-ref ref="CONSOLE" />
    <appender-ref ref="FILE" />
    <appender-ref ref="BT_FILE" />
  </root>

</configuration>