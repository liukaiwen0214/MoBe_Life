.setting-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(168rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f8faf7;
}

.setting-header-card,
.setting-section-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

/* ===== 页面头部 ===== */
.setting-page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #243024;
  line-height: 1.4;
}

.setting-page-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #8f998f;
  line-height: 1.7;
}

/* ===== 设置项 ===== */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
}

.setting-item + .setting-item {
  border-top: 1rpx solid rgba(36, 48, 36, 0.04);
}

.setting-item-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.setting-item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
}

.setting-accent--green {
  background: #edf8f0;
  color: #35c86a;
}

.setting-accent--blue {
  background: #eef4ff;
  color: #5f8fe8;
}

.setting-accent--orange {
  background: #fff4e8;
  color: #f0a24b;
}

.setting-accent--purple {
  background: #f5efff;
  color: #ac7af0;
}

.setting-item-main {
  flex: 1;
  min-width: 0;
}

.setting-item-title {
  font-size: 27rpx;
  font-weight: 600;
  color: #243024;
  line-height: 1.45;
}

.setting-item-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #99a299;
  line-height: 1.6;
}

.setting-item-meta {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #6d776d;
  line-height: 1.4;
}

.setting-item-arrow {
  flex-shrink: 0;
  font-size: 30rpx;
  color: #b4beb4;
  line-height: 1;
}