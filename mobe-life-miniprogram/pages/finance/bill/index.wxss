.bill-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(200rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f8faf7;
}

.bill-summary-card,
.bill-filter-card,
.bill-section-card,
.bill-empty-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

/* ===== 顶部摘要 ===== */
.bill-summary-card {
  display: flex;
  align-items: stretch;
}

.bill-summary-item {
  flex: 1;
  min-width: 0;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.bill-summary-item:first-child {
  padding-left: 0;
}

.bill-summary-item:last-child {
  padding-right: 0;
}

.bill-summary-item + .bill-summary-item {
  border-left: 1rpx solid #edf2e8;
}

.bill-summary-label {
  font-size: 22rpx;
  color: #8d988d;
  line-height: 1.5;
}

.bill-summary-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #243024;
  line-height: 1.3;
  word-break: break-all;
}

.bill-summary-value--expense {
  color: #e35f5f;
}

.bill-summary-value--income {
  color: #20a35a;
}

/* ===== 筛选区 ===== */
.bill-filter-tabs {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.bill-filter-tab {
  min-width: 98rpx;
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f3f6f1;
  color: #8d988d;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 54rpx;
  text-align: center;
  box-sizing: border-box;
}

.bill-filter-tab--active {
  background: #35c86a;
  color: #ffffff;
}

.bill-filter-chip-row {
  margin-top: 20rpx;
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.bill-filter-chip {
  height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f7faf5;
  border: 1rpx solid #edf2e8;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.bill-filter-chip-text {
  font-size: 21rpx;
  color: #697469;
  line-height: 1.4;
}

.bill-filter-chip-arrow {
  font-size: 18rpx;
  color: #9aa49a;
  line-height: 1;
}

.bill-search-box {
  margin-top: 20rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #f8faf7;
  border: 1rpx solid #edf2e8;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  box-sizing: border-box;
}

.bill-search-input {
  width: 100%;
  font-size: 24rpx;
  color: #243024;
  line-height: 1.4;
}

.bill-search-placeholder {
  color: #a1aba1;
}

/* ===== 日期分组 ===== */
.bill-section-head {
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  column-gap: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #edf2e8;
}

.bill-section-head-left {
  min-width: 0;
}

.bill-section-date {
  font-size: 24rpx;
  font-weight: 600;
  color: #243024;
  line-height: 1.4;
}

.bill-section-week {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #97a197;
  line-height: 1.4;
}

.bill-section-head-right {
  text-align: right;
}

.bill-section-money {
  font-size: 21rpx;
  line-height: 1.4;
  white-space: nowrap;
}

.bill-section-money--expense {
  color: #6b756b;
}

.bill-section-money--income {
  margin-top: 4rpx;
  color: #97a197;
}

.bill-section-arrow {
  font-size: 24rpx;
  color: #9aa49a;
  line-height: 1;
}

/* ===== 账单项 ===== */
.bill-item {
  padding: 20rpx 0;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.bill-item + .bill-item {
  border-top: 1rpx solid rgba(36, 48, 36, 0.04);
}

.bill-item-accent {
  width: 8rpx;
  height: 26rpx;
  border-radius: 999rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.bill-accent--orange {
  background: #f0a24b;
}

.bill-accent--blue {
  background: #5f8fe8;
}

.bill-accent--green {
  background: #58b882;
}

.bill-accent--green-strong {
  background: #20a35a;
}

.bill-accent--purple {
  background: #ac7af0;
}

.bill-accent--slate {
  background: #8ea0bf;
}

.bill-item-main {
  flex: 1;
  min-width: 0;
}

.bill-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.bill-item-title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #243024;
  line-height: 1.45;
}

.bill-item-amount {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
}

.bill-amount--expense {
  color: #df6666;
}

.bill-amount--income {
  color: #20a35a;
}

.bill-amount--transfer {
  color: #5c676d;
}

.bill-item-sub {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #98a298;
  line-height: 1.5;
}

/* ===== 空状态 ===== */
.bill-empty-card {
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bill-empty-text {
  font-size: 24rpx;
  color: #9aa49a;
  line-height: 1.5;
}

/* ===== 悬浮按钮 ===== */
.bill-create-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(168rpx + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: #35c86a;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 400;
  text-align: center;
  line-height: 104rpx;
  box-shadow: 0 16rpx 28rpx rgba(53, 200, 106, 0.22);
  z-index: 20;
}