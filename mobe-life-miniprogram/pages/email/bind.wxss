/* 核心职责：定义邮箱绑定页的表单样式，让账号安全相关操作保持清晰、克制、低干扰。 */
.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid #f1f3ef;
  border-radius: 32rpx;
  padding: 32rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #243024;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 25rpx;
  line-height: 1.7;
  color: #7a8778;
  margin-bottom: 28rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #243024;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.input-wrap,
.readonly-box {
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border: 1rpx solid #e9eee4;
  border-radius: 20rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.readonly-box {
  /* 已绑定邮箱不允许直接编辑，所以视觉上故意弱化成只读容器。 */
  background: #f7f9f5;
}

.field-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #243024;
}

.input::placeholder {
  color: #b6beb2;
}

.readonly-text {
  font-size: 28rpx;
  color: #5f6f5f;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.code-input-wrap {
  flex: 1;
  min-width: 0;
}

.code-btn {
  width: 206rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 20rpx;
  background: #ebebeb;
  color: #243024;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;
  text-align: center;
}

.code-btn[disabled] {
  opacity: 0.7;
}

.code-btn::after {
  border: none;
}

.tips {
  font-size: 23rpx;
  line-height: 1.8;
  color: #8b9688;
  margin: 4rpx 0 28rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  background: #22ab74;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0;
  text-align: center;
}

.submit-btn::after {
  border: none;
}

.cancel-wrap {
  padding-top: 20rpx;
  text-align: center;
}

.cancel-text {
  font-size: 28rpx;
  color: #8b9688;
}

.bottom-note {
  padding: 28rpx 0 0;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.8;
  color: #c0c7bc;
}
