.page {
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.todo-header-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.todo-header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #243024;
  margin-bottom: 12rpx;
}

.todo-header-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: #708070;
}

.project-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.project-title {
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #243024;
  margin-bottom: 14rpx;
}

.project-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}

.project-meta-item {
  font-size: 22rpx;
  color: #708070;
}

.project-progress {
  font-size: 22rpx;
  color: #35c86a;
  font-weight: 700;
}

.project-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.project-status {
  font-size: 22rpx;
  color: #35c86a;
  font-weight: 600;
}

.project-update {
  font-size: 22rpx;
  color: #8c988c;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #35c86a;
  color: #ffffff;
  font-size: 52rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(53, 200, 106, 0.24);
}