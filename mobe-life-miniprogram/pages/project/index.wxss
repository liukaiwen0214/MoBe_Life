/*
 * 核心职责：定义小程序 `project` 页面或组件的样式表现。
 * 所属业务模块：小程序展示层 / 样式。
 * 重要依赖关系或外部约束：样式类名需要与对应 WXML 模板保持一致，改动会直接影响页面视觉布局。
 */
.page {
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.goal-overview-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.goal-overview-highlight {
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #243024;
  margin-bottom: 12rpx;
}

.goal-overview-summary {
  font-size: 24rpx;
  line-height: 1.8;
  color: #7a867a;
}

.goal-section-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 12rpx 20rpx 18rpx;
  margin-bottom: 20rpx;
}

.goal-section-card--completed {
  background: #fcfdfb;
}

.goal-section-title {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #243024;
}

.goal-row {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid #f3f5f1;
}

.goal-row:last-child {
  border-bottom: none;
}

.goal-row--completed {
  opacity: 0.92;
}

.goal-row-main {
  flex: 1;
  min-width: 0;
}

.goal-row-title {
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #243024;
  margin-bottom: 12rpx;
  word-break: break-word;
}

.goal-row-title--completed {
  color: #425042;
}

.goal-row-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.goal-row-meta-item {
  font-size: 22rpx;
  color: #708070;
}

.goal-row-progress {
  font-size: 24rpx;
  color: #35c86a;
  font-weight: 700;
}

.goal-row-progress--completed {
  color: #6c8f74;
}

.goal-row-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.goal-row-status {
  font-size: 22rpx;
  color: #35c86a;
  font-weight: 600;
}

.goal-row-status--completed {
  color: #6c8f74;
}

.goal-row-update {
  font-size: 22rpx;
  color: #8c988c;
}

.goal-row-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #b7c0b3;
  flex-shrink: 0;
}

.goal-empty {
  padding: 20rpx 8rpx 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9aa49a;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #35c86a;
  color: #ffffff;
  font-size: 52rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(53, 200, 106, 0.24);
}