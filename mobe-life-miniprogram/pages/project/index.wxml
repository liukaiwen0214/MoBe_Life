<view class="page">
  <view class="todo-header-card">
    <view class="todo-header-title">项目</view>
    <view class="todo-header-desc">{{summaryText}}</view>
  </view>

  <block wx:for="{{projectList}}" wx:key="id" wx:for-item="item">
    <view class="project-card" data-project-id="{{item.id}}" bindtap="handleProjectTap">
      <view class="project-title">{{item.title}}</view>

      <view class="project-meta">
        <text class="project-meta-item">{{item.nodeCount}} 个节点</text>
        <text class="project-meta-item">{{item.taskCount}} 个待办</text>
        <text class="project-progress">{{item.progressText}}</text>
      </view>

      <view class="project-footer">
        <text class="project-status">{{item.statusText}}</text>
        <text class="project-update">{{item.updateText}}</text>
      </view>
    </view>
  </block>

  <view class="fab" bindtap="handleCreateProject">+</view>
</view>

<mobe-tabbar current="writing" current-sub="project"></mobe-tabbar>