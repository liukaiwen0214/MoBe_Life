.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.detail-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
}

.detail-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f7ee;
  color: #7b8d75;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #243024;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.detail-status {
  font-size: 24rpx;
  color: #35c86a;
  font-weight: 600;
}

.detail-time {
  font-size: 24rpx;
  color: #8c988c;
}

.detail-node {
  font-size: 24rpx;
  color: #708070;
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 26rpx;
  line-height: 1.8;
  color: #5f6f5f;
}