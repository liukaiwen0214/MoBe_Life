.form-page {
  padding: 24rpx 24rpx 156rpx;
  box-sizing: border-box;
}

.form-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 36rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.form-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #243024;
  line-height: 1.3;
  margin-bottom: 30rpx;
}

.form-section {
  margin-bottom: 32rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 24rpx;
  color: #8a9588;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.form-input,
.form-textarea,
.select-box,
.date-box {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #edf2e8;
  border-radius: 22rpx;
  background: #ffffff;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #243024;
  line-height: 88rpx;
}

.form-input--main {
  height: 96rpx;
  line-height: 96rpx;
}

.form-textarea {
  min-height: 136rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #243024;
  line-height: 1.65;
}

.form-textarea--remark {
  min-height: 112rpx;
}

.select-box {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
}

.select-box-text {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #243024;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-box-text--placeholder {
  color: #a0aaa0;
}

.select-box-arrow {
  flex-shrink: 0;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 34rpx;
  color: #b7c0b3;
}

.range-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.range-picker-wrap {
  flex: 1;
  min-width: 0;
}

.single-picker-wrap {
  width: 100%;
}

.date-box {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid #edf2e8;
  border-radius: 22rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.date-box--single {
  width: 100%;
}

.date-box-text {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #243024;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date-box-text--placeholder {
  color: #a0aaa0;
}

.range-divider {
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 24rpx;
  color: #8a9588;
}

.form-action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.form-action-btn {
  height: 88rpx;
  border-radius: 24rpx;
  background: #243024;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(36, 48, 36, 0.14);
}