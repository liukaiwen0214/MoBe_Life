<view class="form-page">
  <view class="form-card">
    <view class="form-title">新建待办</view>

    <view class="form-section">
      <view class="form-item">
        <view class="form-label">待办标题</view>
        <input
          class="form-input form-input--main"
          placeholder="请输入待办标题"
          value="{{form.title}}"
          bindinput="handleTitleInput"
        />
      </view>

      <view class="form-item">
        <view class="form-label">待办详细内容</view>
        <textarea
          class="form-textarea"
          placeholder="请输入待办详细内容"
          value="{{form.content}}"
          bindinput="handleContentInput"
        />
      </view>

      <view class="form-item">
        <view class="form-label">备注</view>
        <textarea
          class="form-textarea form-textarea--remark"
          placeholder="请输入备注"
          value="{{form.remark}}"
          bindinput="handleRemarkInput"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="form-item">
        <view class="form-label">归属类型</view>
        <picker
          mode="selector"
          range="{{ownerOptions}}"
          range-key="label"
          value="{{ownerTypeIndex}}"
          bindchange="handleOwnerTypeChange"
        >
          <view class="select-box">
            <view class="select-box-text">{{ownerOptions[ownerTypeIndex].label}}</view>
            <view class="select-box-arrow">›</view>
          </view>
        </picker>
      </view>

      <view wx:if="{{form.directOwnerType === 'PROJECT'}}" class="form-item">
        <view class="form-label">所属项目</view>
        <picker
          mode="selector"
          range="{{projectOptions}}"
          range-key="label"
          value="{{projectIndex}}"
          bindchange="handleProjectChange"
        >
          <view class="select-box">
            <view class="select-box-text {{projectIndex < 0 ? 'select-box-text--placeholder' : ''}}">
              {{projectIndex >= 0 ? projectOptions[projectIndex].label : '请选择所属项目'}}
            </view>
            <view class="select-box-arrow">›</view>
          </view>
        </picker>
      </view>

      <view wx:if="{{form.directOwnerType === 'GOAL'}}" class="form-item">
        <view class="form-label">所属目标</view>
        <picker
          mode="selector"
          range="{{goalOptions}}"
          range-key="label"
          value="{{goalIndex}}"
          bindchange="handleGoalChange"
        >
          <view class="select-box">
            <view class="select-box-text {{goalIndex < 0 ? 'select-box-text--placeholder' : ''}}">
              {{goalIndex >= 0 ? goalOptions[goalIndex].label : '请选择所属目标'}}
            </view>
            <view class="select-box-arrow">›</view>
          </view>
        </picker>
      </view>

      <view wx:if="{{form.directOwnerType === 'NODE'}}" class="form-item">
        <view class="form-label">所属节点</view>
        <picker
          mode="selector"
          range="{{nodeOptions}}"
          range-key="label"
          value="{{nodeIndex}}"
          bindchange="handleNodeChange"
        >
          <view class="select-box">
            <view class="select-box-text {{nodeIndex < 0 ? 'select-box-text--placeholder' : ''}}">
              {{nodeIndex >= 0 ? nodeOptions[nodeIndex].label : '请选择所属节点'}}
            </view>
            <view class="select-box-arrow">›</view>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-section">
      <view class="form-item">
        <view class="form-label">计划日期范围</view>

        <view class="range-row">
          <view class="range-picker-wrap">
            <picker mode="date" value="{{form.planDateStart}}" bindchange="handlePlanDateStartChange">
              <view class="date-box">
                <view class="date-box-text {{form.planDateStart ? '' : 'date-box-text--placeholder'}}">
                  {{form.planDateStart || '开始日期'}}
                </view>
              </view>
            </picker>
          </view>

          <view class="range-divider">至</view>

          <view class="range-picker-wrap">
            <picker mode="date" value="{{form.planDateEnd}}" bindchange="handlePlanDateEndChange">
              <view class="date-box">
                <view class="date-box-text {{form.planDateEnd ? '' : 'date-box-text--placeholder'}}">
                  {{form.planDateEnd || '结束日期'}}
                </view>
              </view>
            </picker>
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">截止日期</view>

        <view class="single-picker-wrap">
          <picker mode="date" value="{{form.deadlineDate}}" bindchange="handleDeadlineDateChange">
            <view class="date-box date-box--single">
              <view class="date-box-text {{form.deadlineDate ? '' : 'date-box-text--placeholder'}}">
                {{form.deadlineDate || '请选择截止日期'}}
              </view>
              <view class="select-box-arrow">›</view>
            </view>
          </picker>
        </view>
      </view>
    </view>
  </view>

  <view class="form-action-bar">
    <view class="form-action-btn" bindtap="handleSubmit">
      保存
    </view>
  </view>
</view>