/*
 * 核心职责：定义小程序 `task` 页面或组件的样式表现。
 * 所属业务模块：小程序展示层 / 样式。
 * 重要依赖关系或外部约束：样式类名需要与对应 WXML 模板保持一致，改动会直接影响页面视觉布局。
 */
.page {
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.todo-header-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.todo-header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #243024;
  margin-bottom: 12rpx;
}

.todo-header-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: #708070;
}

.group-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 28rpx;
  padding: 12rpx 20rpx 20rpx;
  margin-bottom: 20rpx;
}

.group-header {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.group-header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #243024;
}

.group-arrow {
  font-size: 20rpx;
  color: #9cab9c;
}

.group-body {
  padding-top: 8rpx;
}

.task-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f5f1;
}

.task-row:last-child {
  border-bottom: none;
}

.task-action-box {
  width: 34rpx;
  height: 34rpx;
  margin-top: 8rpx;
  border-radius: 10rpx;
  border: 2rpx solid #d7e5d1;
  background: #ffffff;
  flex-shrink: 0;
  box-sizing: border-box;
}

.task-content {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #243024;
  margin-bottom: 10rpx;
  word-break: break-word;
}
.task-row-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 8rpx;
}

.task-row-meta-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.task-row-status {
  font-size: 22rpx;
  line-height: 30rpx;
  color: #35c86a;
  font-weight: 600;
  flex-shrink: 0;
}

.task-row-time {
  font-size: 22rpx;
  line-height: 30rpx;
  color: #8c988c;
  flex-shrink: 0;
}

.task-belong {
  display: block;
  font-size: 22rpx;
  line-height: 35rpx;
  color: #9aa49a;
  text-align: right;
  max-width: 300rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-top: 2rpx;
}
.task-row-time--overdue {
  color: #d96c6c;
}

.task-row-overdue {
  font-size: 22rpx;
  line-height: 30rpx;
  color: #d96c6c;
  font-weight: 600;
  flex-shrink: 0;
}
.task-node-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}
.panel {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
}

.panel-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f7ee;
  color: #7b8d75;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #243024;
  margin-bottom: 16rpx;
}

.panel-desc {
  font-size: 26rpx;
  line-height: 1.8;
  color: #708070;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #35c86a;
  color: #ffffff;
  font-size: 52rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(53, 200, 106, 0.24);
}

.group-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.group-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f1f6eb;
  color: #6f8d66;
  font-size: 20rpx;
  line-height: 1;
}

.node-row {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f3f5f1;
}

.node-row:last-child {
  border-bottom: none;
}

.node-row-main {
  flex: 1;
  min-width: 0;
}

.node-row-title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #243024;
  margin-bottom: 8rpx;
  word-break: break-word;
}

.node-row-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.node-row-count {
  font-size: 22rpx;
  color: #35c86a;
  font-weight: 600;
}

.node-row-update {
  font-size: 22rpx;
  color: #8c988c;
}

.node-row-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #b7c0b3;
  flex-shrink: 0;
}
.group-header {
  padding: 8rpx 0;
}

.group-header-main {
  width: 100%;
}

.group-header-top {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.group-header-left {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #243024;
  line-height: 1.4;
  word-break: break-word;
}

.group-summary {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8c988c;
}

.group-arrow {
  font-size: 28rpx;
  color: #8fa08f;
  flex-shrink: 0;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.group-arrow--collapsed {
  transform: rotate(180deg);
}