<!--
  核心职责：定义小程序 `task` 页面或组件的结构模板。
  所属业务模块：小程序展示层 / 结构模板。
  重要依赖关系或外部约束：模板中的字段和事件名需要与对应 JS 文件中的 data、methods 和组件属性严格一致。
-->
<view class="page">
  <view class="todo-header-card">
    <view class="todo-header-title">待办</view>
    <view class="todo-header-desc">{{summaryText}}</view>
  </view>

  <block wx:for="{{todoSections}}" wx:key="key" wx:for-item="section">
    <view class="group-card">
      <view class="group-header" data-key="{{section.key}}" bindtap="handleToggleSection">
        <view class="group-header-main">
          <view class="group-header-top">
            <view class="group-header-left">
              <text class="group-title">{{section.title}}</text>
            </view>
            <text class="group-arrow {{section.collapsed ? 'group-arrow--collapsed' : ''}}">⌃</text>
          </view>

          <view wx:if="{{section.summary}}" class="group-summary">
            {{section.summary}}
          </view>
        </view>
      </view>

      <view wx:if="{{!section.collapsed}}" class="group-body">
        <block wx:if="{{section.activeTasks && section.activeTasks.length}}">
          <block wx:for="{{section.activeTasks}}" wx:key="id" wx:for-item="task">
            <view class="task-row {{task.rowClass}}">
              <view wx:if="{{task.colorCode}}" class="task-accent" style="background: {{task.colorCode}};"></view>

              <view class="task-action-box" style="{{task.statusColor ? 'border-color:' + task.statusColor + ';background:' + task.statusColor + '22;' : ''}}" data-task-id="{{task.id}}" data-is-terminal="{{task.isTerminal}}" bindtap="handleTaskAction"></view>

              <view class="task-content" data-task-id="{{task.id}}" bindtap="handleTaskTap">
                <view class="task-title">{{task.title}}</view>
                <view class="task-row-meta">
                  <view class="task-row-meta-left">
                    <view class="task-row-status" style="{{task.statusColor ? 'color:' + task.statusColor + ';background:' + task.statusColor + '22;' : ''}}">
                      {{task.statusText}}
                    </view>
                    <view class="task-row-time {{task.isOverdue ? 'task-row-time--overdue' : ''}}">
                      {{task.timeText}}
                    </view>
                    <view wx:if="{{task.isOverdue}}" class="task-row-overdue">
                      {{task.overdueText}}
                    </view>
                  </view>
                  <view wx:if="{{task.belongText}}" class="task-belong">
                    {{task.belongText}}
                  </view>
                </view>
              </view>
            </view>
          </block>
        </block>

        <view wx:if="{{section.completedTasks && section.completedTasks.length}}" class="completed-block">
          <view class="completed-title">已完成</view>

          <block wx:for="{{section.visibleCompletedTasks}}" wx:key="id" wx:for-item="task">
            <view class="task-row {{task.rowClass}}">
              <view wx:if="{{task.colorCode}}" class="task-accent" style="background: {{task.colorCode}};"></view>

              <view class="task-action-box task-action-box--done" style="{{task.statusColor ? 'border-color:' + task.statusColor + ';background:' + task.statusColor + ';' : ''}}" data-task-id="{{task.id}}" data-is-terminal="{{task.isTerminal}}" bindtap="handleTaskAction">
                ✓
              </view>

              <view class="task-content" data-task-id="{{task.id}}" bindtap="handleTaskTap">
                <view class="task-title task-title--completed">{{task.title}}</view>
                <view class="task-row-meta">
                  <view class="task-row-meta-left">
                    <view class="task-row-status task-row-status--done" style="{{task.statusColor ? 'color:' + task.statusColor + ';background:' + task.statusColor + '22;' : ''}}">
                      {{task.statusText}}
                    </view>
                    <view class="task-row-time task-row-time--done">{{task.timeText}}</view>
                  </view>
                  <view wx:if="{{task.belongText}}" class="task-belong task-belong--completed">
                    {{task.belongText}}
                  </view>
                </view>
              </view>
            </view>
          </block>

          <view wx:if="{{section.completedHiddenCount > 0}}" class="completed-more" data-key="{{section.key}}" bindtap="handleShowMoreCompleted">
            查看更多已完成（{{section.completedHiddenCount}}）
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="fab" bindtap="handleCreateTask">+</view>
</view>

<mobe-tabbar current="writing" current-sub="todo"></mobe-tabbar>