<!-- 核心职责：渲染个人中心资料卡片与账号安全入口。 -->
<view class="page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else class="content">
    <view class="top-card">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
        <image class="avatar" src="{{profile.avatar}}" mode="aspectFill"></image>
      </button>

      <view class="nickname">{{profile.nickname}}</view>
      <view class="signature">{{profile.signature}}</view>
    </view>

    <view class="info-card">
      <view class="info-item" bindtap="handleGender">
        <view class="info-left">
          <image class="item-icon" src="/assets/icons/gender.png" mode="aspectFit"></image>
          <text class="info-label">性别</text>
        </view>
        <view class="info-right">
          <text class="info-value">{{profile.genderText}}</text>
          <text class="arrow">›</text>
        </view>
      </view>

      <!-- 出生日期使用 picker 包裹整行，而不是额外放一个按钮，是为了保持资料卡片的交互一致性。 -->
      <picker mode="date" value="{{birthdayPickerValue}}" bindchange="handleBirthdayChange">
        <view class="info-item">
          <view class="info-left">
            <image class="item-icon" src="/assets/icons/birthday.png" mode="aspectFit"></image>
            <text class="info-label">出生日期</text>
          </view>
          <view class="info-right">
            <text class="info-value">{{profile.birthdayText}}</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </picker>

      <view class="phone-row-wrap">
        <view class="info-item">
          <view class="info-left">
            <image class="item-icon" src="/assets/icons/phone.png" mode="aspectFit"></image>
            <text class="info-label">手机号</text>
          </view>
          <view class="info-right">
            <text class="info-value">{{profile.phoneText}}</text>
            <text class="arrow">›</text>
          </view>
        </view>

        <!-- 透明按钮覆盖整行，是为了复用微信官方手机号授权能力，同时不破坏卡片式 UI。 -->
        <button class="phone-overlay-btn" open-type="getPhoneNumber" bindgetphonenumber="handleGetPhoneNumber"></button>
      </view>

      <view class="info-item" bindtap="handleEmail">
        <view class="info-left">
          <image class="item-icon" src="/assets/icons/email.png" mode="aspectFit"></image>
          <text class="info-label">邮箱</text>
        </view>
        <view class="info-right">
          <text class="info-value">{{profile.emailText}}</text>
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="info-item no-border" bindtap="handlePassword">
        <view class="info-left">
          <image class="item-icon" src="/assets/icons/password.png" mode="aspectFit"></image>
          <text class="info-label">修改密码</text>
        </view>
        <view class="info-right">
          <text class="info-value">去设置</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <button class="logout-btn" bindtap="handleLogout">
      <text>退出登录</text>
    </button>

    <view class="danger-wrap" bindtap="handleCancelAccount">
      <view class="danger-top">
        <image class="danger-icon" src="/assets/icons/cancel-account.svg" mode="aspectFit"></image>
        <text class="danger-text">注销账号</text>
      </view>
      <view class="danger-desc">
        注销账号是永久性的，您的所有关联数据将被从服务器中移除。
      </view>
    </view>
  </view>
</view>
