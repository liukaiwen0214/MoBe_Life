/* 核心职责：定义个人中心的卡片式布局，强化“资料管理”和“账号安全”两个阅读层次。 */
.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.loading-wrap {
  padding-top: 220rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #5f6f5f;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.top-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 32rpx;
  text-align: center;
  border: 1rpx solid #f1f3ef;
}

.avatar {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  display: block;
  margin: 0 auto 24rpx;
  background: #f6f8f4;
}

.avatar-btn {
  width: 148rpx;
  height: 148rpx;
  padding: 0;
  margin: 0 auto 24rpx;
  border: none;
  background: transparent;
  border-radius: 50%;
}

.avatar-btn::after {
  border: none;
}

.nickname {
  font-size: 44rpx;
  font-weight: 700;
  color: #243024;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.signature {
  font-size: 26rpx;
  color: #5f6f5f;
  line-height: 1.6;
}

.info-card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid #f1f3ef;
}

.info-item {
  min-height: 108rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  border-bottom: 1rpx solid #edf2e8;
}

.no-border {
  border-bottom: none;
}

.info-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-width: 0;
}

.item-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.danger-wrap {
  padding: 20rpx 0 0;
  text-align: center;
}

.danger-top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.danger-icon {
  width: 26rpx;
  height: 26rpx;
}

.danger-text {
  font-size: 28rpx;
  color: #d84f4f;
  font-weight: 600;
}

.danger-desc {
  font-size: 22rpx;
  line-height: 1.8;
  color: #b8b8b8;
  padding: 0 64rpx;
}

.info-value {
  font-size: 26rpx;
  color: #5f6f5f;
  text-align: right;
  word-break: break-all;
}

.arrow {
  font-size: 34rpx;
  color: #b7c3b1;
  line-height: 1;
  margin-left: 4rpx;
}

.logout-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #ebebeb;
  color: #243024;
}

.info-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
  max-width: 62%;
}

.logout-btn::after {
  border: none;
}

.phone-row-wrap {
  position: relative;
}

.phone-overlay-btn {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  z-index: 2;
}

.phone-overlay-btn::after {
  border: none;
}
