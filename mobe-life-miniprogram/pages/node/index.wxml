<!--
  核心职责：定义小程序 `node` 页面或组件的结构模板。
  所属业务模块：小程序展示层 / 结构模板。
  重要依赖关系或外部约束：模板中的字段和事件名需要与对应 JS 文件中的 data、methods 和组件属性严格一致。
-->
<view class="page">
  <block wx:for="{{nodeSections}}" wx:key="key" wx:for-item="section">
    <view class="group-card">
      <view class="group-header">
        <view class="group-header-left">
          <text class="group-title">{{section.title}}</text>
        </view>
      </view>

      <view class="group-body">
        <block wx:for="{{section.items}}" wx:key="id" wx:for-item="item">
          <view class="node-row" data-node-id="{{item.id}}" bindtap="handleNodeTap">
            <view class="node-row-main">
              <view class="node-row-title">{{item.title}}</view>
              <view class="node-row-meta">
                <text class="node-row-owner">{{item.ownerName}}</text>
                <text class="node-row-count">{{item.taskCount}} 个待办</text>
                <text class="node-row-update">{{item.updateText}}</text>
              </view>
            </view>
            <text class="node-row-arrow">›</text>
          </view>
        </block>
      </view>
    </view>
  </block>

  <view class="fab" bindtap="handleCreateNode">+</view>
</view>

<mobe-tabbar current="writing" current-sub="node"></mobe-tabbar>