/*
 * 核心职责：定义小程序 `node` 页面或组件的样式表现。
 * 所属业务模块：小程序展示层 / 样式。
 * 重要依赖关系或外部约束：样式类名需要与对应 WXML 模板保持一致，改动会直接影响页面视觉布局。
 */
.page {
  padding: 24rpx 24rpx 156rpx;
  box-sizing: border-box;
}

.form-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 36rpx 32rpx 40rpx;
}

.form-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #243024;
  margin-bottom: 28rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f4ee;
}

.form-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.form-label {
  font-size: 24rpx;
  color: #8a9588;
  margin-bottom: 14rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: #243024;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #243024;
}

.form-item--clickable {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.form-item--clickable .form-label {
  margin-bottom: 0;
  flex-shrink: 0;
}

.form-value-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  min-width: 0;
}

.form-value {
  font-size: 28rpx;
  color: #2f3b2f;
  line-height: 1.7;
  text-align: right;
  word-break: break-word;
}

.form-arrow {
  font-size: 28rpx;
  line-height: 1;
  color: #b7c0b3;
  flex-shrink: 0;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.action-btn {
  height: 88rpx;
  border-radius: 24rpx;
  background: #243024;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(36, 48, 36, 0.14);
}