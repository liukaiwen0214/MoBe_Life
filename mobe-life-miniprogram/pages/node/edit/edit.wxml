<!--
  核心职责：定义小程序 `node` 页面或组件的结构模板。
  所属业务模块：小程序展示层 / 结构模板。
  重要依赖关系或外部约束：模板中的字段和事件名需要与对应 JS 文件中的 data、methods 和组件属性严格一致。
-->
<view class="page">
  <view class="form-card">
    <view class="form-title">编辑节点</view>

    <view class="form-item">
      <view class="form-label">节点名称</view>
      <input
        class="form-input"
        placeholder="请输入节点名称"
        value="{{form.title}}"
        bindinput="handleTitleInput"
      />
    </view>

    <view class="form-item form-item--clickable" bindtap="handleOwnerTap">
      <view class="form-label">所属{{form.ownerTypeText}}</view>
      <view class="form-value-row">
        <view class="form-value">{{form.ownerName || '未设置'}}</view>
        <view class="form-arrow">›</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">节点说明</view>
      <textarea
        class="form-textarea"
        placeholder="请输入节点说明"
        value="{{form.content}}"
        bindinput="handleContentInput"
        maxlength="-1"
      />
    </view>

    <view class="form-item">
      <view class="form-label">备注</view>
      <textarea
        class="form-textarea"
        placeholder="请输入备注"
        value="{{form.remark}}"
        bindinput="handleRemarkInput"
        maxlength="-1"
      />
    </view>
  </view>

  <view class="action-bar">
    <view class="action-btn" bindtap="handleSubmit">
      保存修改
    </view>
  </view>
</view>