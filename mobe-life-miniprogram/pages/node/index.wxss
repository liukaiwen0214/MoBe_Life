.node-row {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f3f5f1;
}

.node-row:last-child {
  border-bottom: none;
}

.node-row-main {
  flex: 1;
  min-width: 0;
}

.node-row-title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #243024;
  margin-bottom: 8rpx;
  word-break: break-word;
}

.node-row-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.node-row-owner {
  font-size: 22rpx;
  color: #708070;
}

.node-row-count {
  font-size: 22rpx;
  color: #35c86a;
  font-weight: 600;
}

.node-row-update {
  font-size: 22rpx;
  color: #8c988c;
}

.node-row-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #b7c0b3;
  flex-shrink: 0;
}
.page {
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.todo-header-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.todo-header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #243024;
  margin-bottom: 12rpx;
}

.todo-header-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: #708070;
}

.group-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 28rpx;
  padding: 12rpx 20rpx 20rpx;
  margin-bottom: 20rpx;
}

.group-header {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.group-header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #243024;
}

.group-body {
  padding-top: 8rpx;
}

