.fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #35c86a;
  color: #ffffff;
  font-size: 52rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(53, 200, 106, 0.24);
}