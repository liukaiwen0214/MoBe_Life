/*
 * 核心职责：定义小程序 `node` 页面或组件的样式表现。
 * 所属业务模块：小程序展示层 / 样式。
 * 重要依赖关系或外部约束：样式类名需要与对应 WXML 模板保持一致，改动会直接影响页面视觉布局。
 */
.node-row {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f3f5f1;
}

.node-row:last-child {
  border-bottom: none;
}

.node-row-main {
  flex: 1;
  min-width: 0;
}

.node-row-title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #243024;
  margin-bottom: 8rpx;
  word-break: break-word;
}

.node-row-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.node-row-owner {
  font-size: 22rpx;
  color: #708070;
}

.node-row-count {
  font-size: 22rpx;
  color: #35c86a;
  font-weight: 600;
}

.node-row-update {
  font-size: 22rpx;
  color: #8c988c;
}

.node-row-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #b7c0b3;
  flex-shrink: 0;
}
.page {
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.group-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 28rpx;
  padding: 12rpx 20rpx 20rpx;
  margin-bottom: 20rpx;
}

.group-header {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.group-header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #243024;
}

.group-body {
  padding-top: 8rpx;
}

