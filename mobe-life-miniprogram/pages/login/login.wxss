/* 核心职责：定义登录页的极简首屏样式，让用户尽快完成进入系统的动作。 */
.page {
  padding: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #243024;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #5f6f5f;
  margin-bottom: 32rpx;
}

.login-btn {
  margin-bottom: 24rpx;
  background: #9caf88;
  color: #ffffff;
  border-radius: 16rpx;
}
