.page {
  padding: 24rpx 24rpx 156rpx;
  box-sizing: border-box;
}

.detail-card {
  background: #ffffff;
  border: 1rpx solid #edf2e8;
  border-radius: 32rpx;
  padding: 40rpx 32rpx 44rpx;
}

.detail-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f7ee;
  color: #7b8d75;
  font-size: 22rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 42rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #243024;
  margin-bottom: 20rpx;
  word-break: break-word;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.detail-status {
  font-size: 28rpx;
  color: #35c86a;
  font-weight: 600;
}

.detail-time {
  font-size: 24rpx;
  color: #8c988c;
}

.detail-summary {
  font-size: 26rpx;
  line-height: 1.8;
  color: #708070;
}

.detail-divider {
  height: 1rpx;
  background: #eef3ea;
  margin: 28rpx 0;
}

.detail-note-block {
  display: flex;
  flex-direction: column;
}

.detail-note-title {
  font-size: 24rpx;
  color: #8a9588;
  margin-bottom: 14rpx;
}

.detail-note-main {
  font-size: 28rpx;
  color: #405040;
  line-height: 1.85;
  word-break: break-word;
}

.detail-note-extra {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f4ee;
}

.detail-note-extra-label {
  font-size: 22rpx;
  color: #9aa49a;
  margin-bottom: 8rpx;
}

.detail-note-extra-text {
  font-size: 25rpx;
  color: #6d786d;
  line-height: 1.8;
  word-break: break-word;
}

.section-block {
  margin-top: 4rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.detail-subtitle {
  font-size: 24rpx;
  color: #8a9588;
}

.detail-subtitle--strong {
  font-size: 26rpx;
  font-weight: 600;
  color: #4f614f;
}

.section-link {
  font-size: 22rpx;
  color: #35c86a;
  line-height: 1.6;
}

.flow-scroll {
  width: 100%;
}

.flow-track {
  display: flex;
  align-items: flex-start;
  margin-top: 8rpx;
  overflow-x: auto;
  overflow-y: hidden;
  white-space: nowrap;
  padding: 8rpx 8rpx 12rpx;
  box-sizing: border-box;
}

.flow-step {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  flex-shrink: 0;
}

.flow-step-top {
  position: relative;
  width: 100%;
  height: 28rpx;
}

.flow-step-line {
  position: absolute;
  left: 50%;
  right: -50%;
  top: 50%;
  height: 2rpx;
  background: #e1e8de;
  transform: translateY(-50%);
}

.flow-step:last-child .flow-step-line {
  display: none;
}

.flow-step-line--passed,
.flow-step-line--current {
  background: #8fc9a0;
}

.flow-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #dfe8dc;
  transform: translate(-50%, -50%);
}

.flow-dot--passed {
  background: #8fc9a0;
}

.flow-dot--current {
  width: 22rpx;
  height: 22rpx;
  background: #2db35f;
  box-shadow: 0 0 0 8rpx rgba(45, 179, 95, 0.12);
}

.flow-label {
  margin-top: 18rpx;
  width: 100%;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a9588;
  text-align: center;
  word-break: break-word;
}

.flow-label--current {
  color: #2db35f;
  font-weight: 600;
}

.node-panel {
  border-bottom: 1rpx solid #f3f5f1;
}

.node-panel:last-child {
  border-bottom: none;
}

.node-panel-head {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
}

.node-panel-head-main {
  flex: 1;
  min-width: 0;
}

.node-panel-title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #243024;
  margin-bottom: 8rpx;
  word-break: break-word;
}

.node-panel-desc {
  font-size: 22rpx;
  color: #708070;
}

.node-panel-head-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.node-panel-link {
  font-size: 22rpx;
  color: #35c86a;
}

.node-panel-arrow {
  font-size: 28rpx;
  color: #8fa08f;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.node-panel-arrow--collapsed {
  transform: rotate(180deg);
}

.node-panel-body {
  padding: 0 0 10rpx;
}

.task-row {
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0 18rpx 10rpx;
  border-top: 1rpx solid #f5f7f3;
}

.task-row-main {
  flex: 1;
  min-width: 0;
}

.task-row-title {
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #2f3b2f;
  margin-bottom: 6rpx;
  word-break: break-word;
}

.task-row-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7c887c;
}

.task-row-arrow {
  font-size: 30rpx;
  color: #b7c0b3;
  flex-shrink: 0;
}

.node-panel-empty {
  padding: 8rpx 0 18rpx 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #9aa49a;
}

.detail-action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.detail-action-btn {
  height: 88rpx;
  border-radius: 24rpx;
  background: #243024;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(36, 48, 36, 0.14);
}