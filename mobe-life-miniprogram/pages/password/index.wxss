/* 核心职责：定义密码设置页的表单样式，让安全操作保持明确但不过度制造压迫感。 */
.page {
  min-height: 100vh;
  background: #ffffff;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid #f1f3ef;
  border-radius: 32rpx;
  padding: 32rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #243024;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 25rpx;
  line-height: 1.7;
  color: #7a8778;
  margin-bottom: 28rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #243024;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.input {
  width: 100%;
  height: 84rpx;
  border: 1rpx solid #e9eee4;
  border-radius: 20rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #243024;
  background: #ffffff;
}

.input::placeholder {
  color: #b6beb2;
}

.tips {
  font-size: 23rpx;
  line-height: 1.8;
  color: #8b9688;
  margin: 4rpx 0 28rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  background: #22ab74;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0;
  text-align: center;
  display: block;
}

.submit-btn::after {
  border: none;
}
