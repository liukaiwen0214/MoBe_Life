<!--
  核心职责：定义小程序 `index` 页面或组件的结构模板。
  所属业务模块：小程序展示层 / 结构模板。
  重要依赖关系或外部约束：模板中的字段和事件名需要与对应 JS 文件中的 data、methods 和组件属性严格一致。
-->
<view class="mobe-tabbar-shell">
  <!-- 事项模块内部导航 -->
  <view wx:if="{{isTaskModule}}" class="mobe-tabbar mobe-tabbar--module">
    <view
      wx:for="{{taskModuleNavItems}}"
      wx:for-item="nav"
      wx:key="key"
      class="tab-item"
      data-key="{{nav.key}}"
      bindtap="handleTaskModuleNavTap"
    >
      <image
        class="tab-icon {{currentSub === nav.key ? 'tab-icon--active' : ''}}"
        src="{{nav.icon}}"
        mode="aspectFit"
      ></image>

      <view class="tab-label-row">
        <text class="tab-item-label {{currentSub === nav.key ? 'tab-item-label--active' : ''}}">
          {{nav.label}}
        </text>
      </view>
    </view>
  </view>

  <!-- 全局一级导航 -->
  <view wx:else class="mobe-tabbar">
    <view
      wx:for="{{globalNavItems}}"
      wx:for-item="nav"
      wx:key="key"
      class="tab-item"
      data-key="{{nav.key}}"
      bindtap="handleGlobalNavTap"
    >
      <image
        class="tab-icon {{current === nav.key ? 'tab-icon--active' : ''}}"
        src="{{nav.icon}}"
        mode="aspectFit"
      ></image>

      <view class="tab-label-row">
        <text class="tab-item-label {{current === nav.key ? 'tab-item-label--active' : ''}}">
          {{nav.label}}
        </text>
      </view>
    </view>
  </view>
</view>