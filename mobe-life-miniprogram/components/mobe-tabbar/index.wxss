:host {
  display: block;
}

.mobe-tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.mobe-tabbar {
  height: calc(108rpx + env(safe-area-inset-bottom));
  padding: 20rpx 18rpx env(safe-area-inset-bottom);
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #edf2e8;
}

.mobe-tabbar--module {
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e8eee2;
  box-shadow: 0 -8rpx 20rpx rgba(36, 48, 36, 0.04);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
  display: block;
  opacity: 0.72;
}

.tab-icon--active {
  opacity: 1;
}

.tab-label-row {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.tab-item-label {
  font-size: 22rpx;
  line-height: 1;
  color: #9a9ca8;
  font-weight: 500;
}

.tab-item-label--active {
  color: #35c86a;
  font-weight: 600;
}