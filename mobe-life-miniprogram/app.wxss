page,
view,
text,
button,
input,
textarea,
picker,
navigator {
  font-family: 'MoBeFont', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #243024;
}
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 
