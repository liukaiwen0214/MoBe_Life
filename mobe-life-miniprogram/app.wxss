/* 核心职责：定义小程序全局样式基线，让所有页面默认继承同一套字体和基础视觉语义。 */
page,
view,
text,
button,
input,
textarea,
picker,
navigator {
  font-family: 'MoBeFont', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #243024;
}

page {
  background: #ffffff;
}

button::after {
  border: none;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}
